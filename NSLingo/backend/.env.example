# ---- MongoDB Atlas ----
# Your cluster connection string. Replace <db_password> with your real DB user
# password, and keep "/nslingo" as the database name.
MONGODB_URI=mongodb+srv://myAtlasDBUser:<db_password>@myatlasclusteredu.5v5k9dw.mongodb.net/nslingo?retryWrites=true&w=majority

# ---- Auth ----
# Any long random string. Used to sign JWT tokens.
JWT_SECRET=change-me-to-a-long-random-string

# ---- AI Translator (Google Gemini) ----
# Get a key from https://aistudio.google.com/apikey . If left blank, the
# /translate endpoint falls back to the local dictionary-based translator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Server ----
PORT=4000

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGIN=http://localhost:5173
