# Base URL of the NSLingo backend (Express on Render).
# When unset, the app falls back to local mock data (frontend-first mode).
VITE_API_BASE_URL=

# Example for local backend:
# VITE_API_BASE_URL=http://localhost:4000

# Example for deployed backend:
# VITE_API_BASE_URL=https://nslingo-api.onrender.com
